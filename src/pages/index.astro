---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { AUTHOR, CMP_RSS_PATH } from "../consts";
import { featuredProjects } from "../data/projects";
import {
	cmpChapterPath,
	getCmpChapters,
	isCmpChapterRenderable,
	parseCmpEntryId,
} from "../lib/research-cmp";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allResearch = await getCollection("research");
const cmpChapters = getCmpChapters(allResearch);
const readableCmpChapters = cmpChapters.filter((chapter) => isCmpChapterRenderable(chapter.data.status));
const firstCmpChapter = readableCmpChapters[0];
const firstCmpIds = firstCmpChapter ? parseCmpEntryId(firstCmpChapter.id) : null;
const firstCmpHref = firstCmpIds ? cmpChapterPath(firstCmpIds.part, firstCmpIds.slug) : "/research/cmp/";

const featuredPost = posts.find((p) => p.data.featured) || posts[0];
const recentPosts = posts.filter((p) => p.id !== featuredPost?.id).slice(0, 4);
const homepageProjects = featuredProjects.slice(0, 2);

const pageTitle = `${AUTHOR.name} — Research, Writing, and Software Architecture`;
const pageDescription =
	"Personal site for Leric Zhang: research on the Context Minimization Principle, context cost, correct modification, and AI-era software design.";
const heroImage = "https://images.unsplash.com/photo-1515879218367-8466d910aaa4?w=1920&q=80";

function projectHref(project: (typeof homepageProjects)[number]) {
	return project.primaryAction?.href || project.repo || "/projects/";
}
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="home-hero">
		<img src={heroImage} alt="" loading="eager" decoding="async" />
		<div class="hero-shade"></div>
		<div class="hero-copy">
			<p class="hero-kicker">Research · Writing · Software Architecture</p>
			<h1>Software architecture for the agentic era.</h1>
			<p>
				Research and essays on context cost, correct modification, AI coding agents, and systems whose required
				context stays reachable as they grow.
			</p>
		</div>
	</section>

	<section class="portal-grid" aria-label="Main site sections">
		<a class="portal-card primary" href="/research/cmp/">
			<span>Research / 研究</span>
			<h2>Context Minimization Principle</h2>
			<p>A living book on making sufficient context for realistic modifications cheaper to acquire.</p>
		</a>
		<a class="portal-card" href="/blog/">
			<span>Writing / 文章</span>
			<h2>Essays</h2>
			<p>Shorter arguments about architecture, context operators, agents, and software design under change.</p>
		</a>
		<a class="portal-card" href="/projects/">
			<span>Projects / 项目</span>
			<h2>Working Systems</h2>
			<p>Research artifacts and tools around context acquisition, agent workflows, and design analysis.</p>
		</a>
	</section>

	<section class="cmp-feature">
		<div class="section-copy">
			<p class="kicker">Online book · Living · v0.1</p>
			<h2>Start with CMP</h2>
			<p>
				CMP proposes context cost as the currency of software design: for the modifications a system must
				realistically support, better designs make sufficient context for correct modification cheaper to acquire.
			</p>
		</div>
		<div class="cmp-actions">
			<a href={firstCmpHref}>
				<strong>Start from Part I</strong>
				<span>Begin with the first available chapter</span>
			</a>
			<a href="/research/cmp/">
				<strong>Open full TOC</strong>
				<span>Browse all parts and draft structure</span>
			</a>
			<a href={CMP_RSS_PATH}>
				<strong>CMP RSS</strong>
				<span>Subscribe to research chapter updates</span>
			</a>
		</div>
	</section>

	<section class="content-band">
		<div class="section-header">
			<div>
				<p class="kicker">Recent Essays / 最近文章</p>
				<h2>Writing around the research</h2>
			</div>
			<a class="text-link" href="/blog/">View archive</a>
		</div>

		{
			featuredPost && (
				<div class="essay-layout">
					<PostCard
						title={featuredPost.data.title}
						description={featuredPost.data.description}
						pubDate={featuredPost.data.pubDate}
						heroImage={featuredPost.data.heroImage}
						slug={featuredPost.id}
						category={featuredPost.data.category}
					/>
					<div class="essay-list">
						{recentPosts.map((post) => (
							<a class="essay-row" href={`/blog/${post.id}/`}>
								<span>{post.data.category || "Essay"}</span>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
						))}
					</div>
				</div>
			)
		}
	</section>

	<section class="content-band projects-band">
		<div class="section-header">
			<div>
				<p class="kicker">Projects / 项目</p>
				<h2>Research made operational</h2>
			</div>
			<a class="text-link" href="/projects/">All projects</a>
		</div>
		<div class="project-grid">
			{
				homepageProjects.map((project) => (
					<a class="project-card" href={projectHref(project)} target="_blank" rel="noopener noreferrer">
						<h3>{project.name}</h3>
						<p>{project.summary}</p>
						<div class="project-tags">
							{project.tags.slice(0, 3).map((tag) => (
								<span>{tag}</span>
							))}
						</div>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.home-hero {
		position: relative;
		min-height: clamp(420px, 58vw, 620px);
		margin: 32px 0;
		border-radius: var(--card-radius);
		overflow: hidden;
		background: var(--primary);
	}

	.home-hero img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		margin: 0;
		border-radius: 0;
	}

	.hero-shade {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(0, 0, 0, 0.76) 0%, rgba(0, 0, 0, 0.42) 48%, rgba(0, 0, 0, 0.12) 100%),
			linear-gradient(180deg, rgba(0, 0, 0, 0.18) 0%, rgba(0, 0, 0, 0.42) 100%);
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		min-height: inherit;
		max-width: 760px;
		padding: clamp(28px, 5vw, 56px);
	}

	.kicker {
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 12px;
	}

	.hero-kicker {
		color: rgba(255, 255, 255, 0.78);
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		margin: 0 0 14px;
	}

	.home-hero h1 {
		color: white;
		font-size: clamp(36px, 5.4vw, 58px);
		line-height: 1.05;
		letter-spacing: -0.04em;
		margin: 0 0 18px;
		max-width: 720px;
	}

	.hero-copy p {
		color: rgba(255, 255, 255, 0.86);
		font-size: 18px;
		line-height: 1.65;
		max-width: 620px;
		margin: 0 0 12px;
	}

	.text-link {
		display: inline-flex;
		align-items: center;
		color: var(--accent);
		font-size: 14px;
		font-weight: 700;
		text-decoration: none;
	}

	.text-link:hover {
		text-decoration: underline;
	}

	.portal-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		padding: 32px 0;
	}

	.portal-card {
		border: 1px solid var(--border);
		border-radius: var(--card-radius);
		padding: 22px;
		color: var(--primary);
		text-decoration: none;
		background: white;
		min-height: 210px;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.portal-card:hover,
	.project-card:hover,
	.essay-row:hover,
	.cmp-actions a:hover {
		border-color: rgba(0, 102, 204, 0.35);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		text-decoration: none;
	}

	.portal-card span,
	.essay-row span {
		display: block;
		color: var(--text-muted);
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 12px;
	}

	.portal-card h2 {
		font-size: 21px;
		margin: 0 0 12px;
	}

	.portal-card p {
		color: var(--secondary);
		font-size: 14px;
		line-height: 1.6;
		margin: 0;
	}

	.portal-card.primary {
		background: #f7fbff;
		border-color: rgba(0, 102, 204, 0.22);
	}

	.cmp-feature,
	.content-band {
		border-top: 1px solid var(--border);
		padding: 40px 0;
	}

	.cmp-feature {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
		gap: 36px;
		align-items: start;
	}

	.section-copy h2,
	.section-header h2 {
		font-size: clamp(24px, 3.5vw, 32px);
		margin: 0 0 14px;
	}

	.section-copy p {
		color: var(--secondary);
		line-height: 1.7;
		margin: 0 0 12px;
	}

	.cmp-actions {
		display: grid;
		gap: 12px;
	}

	.cmp-actions a,
	.essay-row,
	.project-card {
		border: 1px solid var(--border);
		border-radius: var(--card-radius);
		background: white;
		color: var(--primary);
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.cmp-actions a {
		padding: 18px 20px;
	}

	.cmp-actions strong,
	.cmp-actions span {
		display: block;
	}

	.cmp-actions strong {
		font-size: 16px;
		margin-bottom: 4px;
	}

	.cmp-actions span {
		color: var(--secondary);
		font-size: 13px;
		line-height: 1.45;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 24px;
		margin-bottom: 24px;
	}

	.essay-layout {
		display: grid;
		grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.05fr);
		gap: 24px;
		align-items: start;
	}

	.essay-list {
		display: grid;
		gap: 12px;
	}

	.essay-row {
		display: block;
		padding: 18px;
	}

	.essay-row h3 {
		font-size: 17px;
		line-height: 1.35;
		margin: 0 0 8px;
	}

	.essay-row p {
		color: var(--secondary);
		font-size: 13px;
		line-height: 1.5;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.projects-band {
		padding-bottom: 72px;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		min-height: 260px;
		padding: 22px;
	}

	.project-card h3 {
		font-size: 21px;
		margin: 0 0 12px;
	}

	.project-card p {
		color: var(--secondary);
		font-size: 14px;
		line-height: 1.6;
		margin: 0 0 20px;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: auto;
	}

	.project-tags span {
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--secondary);
		font-size: 12px;
		font-weight: 700;
		line-height: 1;
		padding: 7px 10px;
	}

	@media (max-width: 900px) {
		.cmp-feature,
		.essay-layout {
			grid-template-columns: 1fr;
		}

		.portal-grid {
			grid-template-columns: 1fr;
		}

		.portal-card {
			min-height: auto;
		}
	}

	@media (max-width: 640px) {
		.home-hero {
			min-height: 540px;
			margin: 20px 0 28px;
		}

		.home-hero h1 {
			font-size: 38px;
		}

		.hero-copy p {
			font-size: 16px;
		}

		.section-header {
			align-items: stretch;
			flex-direction: column;
		}

		.portal-card,
		.project-card {
			padding: 20px;
		}

		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { AUTHOR } from "../consts";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentEssays = posts.slice(0, 3);

const pageTitle = "Context Cost";
const pageDescription =
	"Essays on software design, context cost, and AI-assisted engineering.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="intro">
		<h1>Context Cost</h1>
		<p class="subtitle">Insights on software engineering in the AI era.</p>
		<p class="lead">
			Essays on software design, context cost, and AI-assisted engineering.
			<br />
			By {AUTHOR.name}.
		</p>
	</section>

	<section class="primary-links" aria-label="Primary site entry points">
		<article>
			<h2><a href="/cmp">Context Minimization Principle</a></h2>
			<p>The core theory in the Context Cost research program.</p>
			<a class="text-link" href="/cmp">Start with CMP</a>
		</article>
		<article>
			<h2><a href="/blog">Essays</a></h2>
			<p>Short arguments around software architecture, AI coding agents, and context engineering.</p>
			<a class="text-link" href="/blog">Read the essays</a>
		</article>
		<article>
			<h2><a href="/projects">Projects</a></h2>
			<p>Context Footprint and related prototypes that operationalize the theory.</p>
			<a class="text-link" href="/projects">See the projects</a>
		</article>
	</section>

	<p class="brand-chain">Context Cost → CMP → Context Footprint → AI-assisted software engineering.</p>

	<section class="recent-essays">
		<div class="section-head">
			<h2>Recent Essays</h2>
			<a class="text-link" href="/blog">View all</a>
		</div>
		<ul>
			{recentEssays.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					<p>{post.data.description}</p>
					<small><FormattedDate date={post.data.pubDate} /></small>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>

<style>
	.intro {
		padding: 64px 0 36px;
		max-width: 760px;
	}

	.subtitle {
		font-size: 20px;
		color: var(--secondary);
		margin-bottom: 20px;
	}

	.intro .lead {
		font-size: 17px;
		color: var(--secondary);
		max-width: 760px;
		margin-bottom: 0;
	}

	.primary-links {
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: 26px 0;
		display: grid;
		gap: 20px;
	}

	.primary-links article {
		padding-bottom: 18px;
		border-bottom: 1px solid var(--border-light);
	}

	.primary-links article:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.primary-links h2 {
		font-size: 22px;
		margin: 0 0 8px;
	}

	.primary-links h2 a {
		color: var(--primary);
		text-decoration: none;
	}

	.primary-links p {
		color: var(--secondary);
		margin: 0 0 6px;
	}

	.text-link {
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
	}

	.brand-chain {
		margin: 20px 0 0;
		font-size: 14px;
		color: var(--text-muted);
	}

	.recent-essays {
		padding: 38px 0 8px;
		max-width: 860px;
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 12px;
	}

	.recent-essays h2 {
		font-size: 24px;
		margin: 0;
	}

	.recent-essays ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.recent-essays li {
		padding: 15px 0;
		margin: 0;
		border-bottom: 1px solid var(--border-light);
	}

	.recent-essays li a {
		display: inline-block;
		color: var(--primary);
		font-size: 18px;
		text-decoration: none;
		margin-bottom: 4px;
	}

	.recent-essays li p {
		margin: 0 0 4px;
		color: var(--secondary);
	}

	.recent-essays small {
		color: var(--text-muted);
		font-size: 13px;
	}

	@media (max-width: 720px) {
		.intro {
			padding: 44px 0 24px;
		}

		.subtitle {
			font-size: 18px;
		}

		.primary-links {
			padding: 20px 0;
		}

		.primary-links h2 {
			font-size: 20px;
		}

		.recent-essays li a {
			font-size: 17px;
		}
	}
</style>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { AUTHOR, CMP_SOURCE_REPO, SITE_TITLE } from '../../../consts';
import { getCollection } from 'astro:content';
import {
	CMP_PART_LABELS,
	CMP_PART_ORDER,
	cmpChapterPath,
	getCmpChapters,
	isCmpChapterRenderable,
	parseCmpEntryId,
} from '../../../lib/research-cmp';

const all = await getCollection('research');
const chapters = getCmpChapters(all);

const pageTitle = `Context Minimization Principle (CMP) — Research — ${SITE_TITLE}`;
const pageDescription =
	'Online book: a theory of context cost for correct modification, software design trade-offs, and AI coding agents.';
const canonicalHref = new URL('/research/cmp/', Astro.site).href;

const coverImage = 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80';

const bookJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Book',
	name: 'Context Minimization Principle',
	description: pageDescription,
	url: canonicalHref,
	author: {
		'@type': 'Person',
		name: AUTHOR.name,
		url: AUTHOR.social.github,
	},
	inLanguage: 'en',
	bookFormat: 'https://schema.org/EBook',
	numberOfPages: chapters.length,
};

const bibtex = `@book{zhang2026cmp,
  title = {Context Minimization Principle},
  author = {Lianghui Zhang},
  year = {2026},
  url = {${canonicalHref}},
  note = {Living book, version 0.1}
}`;
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	image={coverImage}
	canonicalHref={canonicalHref}
	jsonLd={bookJsonLd}
>
	<section class="cmp-hero">
		<p class="kicker">Online book · Living · v0.1</p>
		<h1>Context Minimization Principle</h1>
		<p class="subtitle">A theory of context cost for correct modification.</p>
		<div class="hero-meta">
			<span>{AUTHOR.name}</span>
			<span>·</span>
			<a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="license noopener noreferrer"
				>License: CC BY 4.0</a
			>
			<span>·</span>
			<a href={CMP_SOURCE_REPO} target="_blank" rel="noopener noreferrer">Paper repo ↗</a>
		</div>
	</section>

	<section class="cmp-section">
		<h2>Who is this for?</h2>
		<p>
			This book is for software architects and senior engineers asking how software should be designed when AI
			programmers become regular modifiers of the codebase. The central question is not whether agents can produce
			code, but whether the system makes the required context for correct modification reachable to them.
		</p>
		<p>
			CMP gives this problem a vocabulary: context cost, sufficient context, depth, breadth, modification closure,
			and context operators. It is a framework for people who care about architecture as the discipline of making
			future human and AI programmers cheaper, safer, and more reliable modifiers of a living system.
		</p>
	</section>

	<section class="cmp-section">
		<h2>Full table of contents</h2>
		<p class="muted">Draft chapters appear as <em>Coming soon</em> in the sidebar; they are not published as pages yet.</p>
		<div class="toc-wrap">
			{
				CMP_PART_ORDER.map((partId) => {
					const items = chapters.filter((c) => c.data.part === partId);
					if (items.length === 0) return null;
					return (
						<div class="toc-part">
							<h3 class="toc-part-title">{CMP_PART_LABELS[partId]}</h3>
							<ol class="toc-list">
								{items.map((ch) => {
									const ids = parseCmpEntryId(ch.id);
									const ready = ids && isCmpChapterRenderable(ch.data.status);
									const href = ids ? cmpChapterPath(ids.part, ids.slug) : '#';
									return (
										<li>
											{ready ? (
												<a href={href}>{ch.data.title}</a>
											) : (
												<span class="soon">
													{ch.data.title}
													<span class="pill">Coming soon</span>
												</span>
											)}
										</li>
									);
								})}
							</ol>
						</div>
					);
				})
			}
		</div>
	</section>

	<section class="cmp-section">
		<h2>Cite this book</h2>
		<p class="muted">Suggested plain citation:</p>
		<blockquote class="cite-block">
			Lianghui Zhang, <em>Context Minimization Principle</em> (living online book), 2026. {canonicalHref}
		</blockquote>
		<p class="muted">BibTeX:</p>
		<pre class="bib"><code>{bibtex}</code></pre>
	</section>

	<section class="cmp-section">
		<h2>License</h2>
		<p>
			Unless otherwise noted, <em>Context Minimization Principle</em> by {AUTHOR.name} is licensed under
			<a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="license noopener noreferrer"
				>Creative Commons Attribution 4.0 International</a
			>.
		</p>
		<p class="muted">
			This license applies to the CMP online book content, not to the website source code or third-party assets.
		</p>
	</section>

	<section class="cmp-section subscribe">
		<h2>Subscribe</h2>
		<p>
			<a href="/research/cmp/rss.xml">CMP-only RSS</a>
			<span class="dot">·</span>
			<a href="/rss.xml">Blog RSS</a> (unchanged; blog posts only)
		</p>
	</section>
</BaseLayout>

<style>
	.cmp-hero {
		padding: 40px 0 32px;
		border-bottom: 1px solid var(--border);
		margin-bottom: 36px;
	}
	.kicker {
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 12px;
	}
	.cmp-hero h1 {
		font-size: clamp(30px, 5vw, 48px);
		letter-spacing: -0.03em;
		margin: 0 0 12px;
		max-width: 900px;
	}
	.subtitle {
		font-size: 18px;
		line-height: 1.6;
		color: var(--secondary);
		max-width: 720px;
		margin: 0 0 16px;
	}
	.hero-meta {
		font-size: 14px;
		color: var(--text-muted);
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	.cmp-section {
		margin-bottom: 40px;
		max-width: 900px;
	}
	.cmp-section h2 {
		font-size: 22px;
		margin-bottom: 14px;
	}
	.cmp-section p {
		color: var(--primary);
		line-height: 1.7;
	}
	.muted {
		color: var(--secondary);
		font-size: 15px;
	}
	.two-col {
		margin: 0;
		padding-left: 20px;
		line-height: 1.7;
	}
	.toc-wrap {
		display: flex;
		flex-direction: column;
		gap: 28px;
		margin-top: 16px;
	}
	.toc-part-title {
		font-size: 16px;
		margin: 0 0 10px;
		color: var(--primary);
	}
	.toc-list {
		margin: 0;
		padding-left: 20px;
		line-height: 1.65;
	}
	.toc-list li {
		margin-bottom: 8px;
	}
	.soon {
		color: var(--text-muted);
		display: inline-flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
	}
	.pill {
		font-size: 10px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 2px 8px;
		color: var(--secondary);
	}
	.cite-block {
		margin: 12px 0 20px;
		font-size: 15px;
	}
	.bib {
		font-size: 13px;
		line-height: 1.5;
		overflow-x: auto;
	}
	.subscribe .dot {
		margin: 0 10px;
		color: var(--text-muted);
	}
</style>

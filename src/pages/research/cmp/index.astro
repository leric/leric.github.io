---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
	title="CMP has moved"
	description="CMP overview is now located at /cmp."
	canonicalHref={new URL("/cmp", Astro.site).href}
>
	<section class="moved">
		<h1>Context Minimization Principle</h1>
		<p>The main CMP entry page is now available at <a href="/cmp">/cmp</a>.</p>
		<p>This route is kept for compatibility with older links to chapter pages.</p>
	</section>
</BaseLayout>

<style>
	.moved {
		max-width: 760px;
		padding: 56px 0;
	}
</style>

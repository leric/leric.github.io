---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CMP_SOURCE_REPO, SITE_TITLE } from "../../consts";

const pageTitle = `Context Minimization Principle — ${SITE_TITLE}`;
const pageDescription =
	"CMP is a framework for software design as the discipline of reducing context acquisition cost — for humans and AI agents alike.";

type ChapterStatus = "published" | "planned";

interface Chapter {
	num: number;
	title: string;
	description: string;
	status: ChapterStatus;
	href?: string;
}

interface RoadmapPart {
	id: string;
	label: string;
	chapters: Chapter[];
}

const manifesto: Chapter = {
	num: 1,
	title: "Reliable Coding Agents Need Better Codebases",
	description:
		"Better models and better harnesses matter. But agents also need codebases where the right context is cheap to find, trust, and use.",
	status: "published",
	href: "/research/cmp/start/reliable-coding-agents-need-better-codebases/",
};

const parts: RoadmapPart[] = [
	{
		id: "foundations",
		label: "Part I — Foundations",
		chapters: [
			{
				num: 2,
				title: "Software Is Made of Modifications",
				description:
					"Why software development is better understood as continuous modification rather than one-time creation. Features, bug fixes, refactoring, review, and testing all revolve around changing a living system safely.",
				status: "published",
				href: "/research/cmp/foundations/software-is-made-of-modifications/",
			},
			{
				num: 3,
				title: "The Cost of Modification",
				description:
					"Required context, explicit and implicit knowledge, and why context cost is the shared currency of software engineering.",
				status: "published",
				href: "/research/cmp/foundations/the-cost-of-modification/",
			},
			{
				num: 4,
				title: "The Context Minimization Principle",
				description:
					"The formal statement of CMP and the four constraints that turn it from a slogan into a comparative frame for software design.",
				status: "published",
				href: "/research/cmp/foundations/the-context-minimization-principle/",
			},
		],
	},
	{
		id: "shape",
		label: "Part II — The Shape of Context",
		chapters: [
			{
				num: 5,
				title: "Depth: When Simple Calls Become Long Investigations",
				description:
					"Depth is the context cost of acquiring the behavioral meaning of a focal artifact. This chapter explains why a short call site can hide a long investigation, and why boundaries only stop traversal when their contracts do the work.",
				status: "published",
				href: "/research/cmp/shape/depth/",
			},
			{
				num: 6,
				title: "Breadth: The Things You Forgot to Change",
				description:
					"Breadth is the cost of acquiring every artifact that must be considered together for a realistic change to be correct — and of knowing the modification closure is complete.",
				status: "published",
				href: "/research/cmp/shape/breadth/",
			},
			{
				num: 7,
				title: "Context Transformation: How Design Changes the Shape of Context",
				description:
					"Breadth selects artifacts; depth prices each one. Design moves transform context by reducing, relocating, indexing, or making it checkable.",
				status: "published",
				href: "/research/cmp/shape/context-transformation/",
			},
		],
	},
	{
		id: "principles",
		label: "Part III — Design as Context Engineering",
		chapters: [
			{
				num: 8,
				title: "Boundary Principles: Hiding Context, Not Code",
				description:
					"Boundary principles are context operators on depth: semantic contracts that let modifiers stop without loading implementation details behind them.",
				status: "published",
				href: "/research/cmp/principles/boundary-principles/",
			},
			{
				num: 9,
				title: "Locality Principles: Designing Against Omission",
				description:
					"Locality makes modification closure reachable from every legitimate entry point. This chapter reframes DRY, SRP, and cohesion as design against omission — for humans and agents.",
				status: "published",
				href: "/research/cmp/principles/locality-principles/",
			},
			{
				num: 10,
				title: "Architecture as Context Routing",
				description:
					"Architecture is a routing map for context acquisition. This chapter explains how layers, bounded contexts, framework conventions, and system boundaries make decision placement predictable.",
				status: "published",
				href: "/research/cmp/principles/architecture-as-context-routing/",
			},
			{
				num: 11,
				title: "Testing: Testability as Context Cost",
				description:
					"Testability is the cost of acquiring the context needed to verify behavior. This chapter connects testing to CMP through verification context and explains why TDD applies testability pressure early.",
				status: "published",
				href: "/research/cmp/principles/testability-as-context-cost/",
			},
			{
				num: 12,
				title: "Programming Languages Are Boundary Infrastructure",
				description:
					"A programming language is not just syntax for a machine — it is the base layer of boundary infrastructure. Types, modules, visibility, nullability, exhaustive matching, ownership, and effect systems turn design intent into enforceable boundaries that protect modification.",
				status: "published",
				href: "/research/cmp/principles/programming-languages-as-boundary-infrastructure/",
			},
		],
	},
	{
		id: "economics",
		label: "Part IV — Practice: Design in the Agent Era",
		chapters: [
			{
				num: 13,
				title: "Over-Engineering, YAGNI, and Bad Context Bets",
				description:
					"Over-engineering is not \"too much design\" - it is paying present context cost for future savings that do not arrive, arrive along the wrong axis, or would have been cheaper to defer. YAGNI and careless deferral are the opposite failure: refusing to bet when the future modification is reasonably foreseeable. This chapter frames both as wrong bets on expected context cost.",
				status: "published",
				href: "/research/cmp/practice/over-engineering-yagni-and-bad-context-bets/",
			},
			{
				num: 14,
				title: "How Cheap Code Rewrites Design Bets",
				description:
					"When agents make code itself cheap, the cost-benefit math behind every design decision changes. Investments that looked like over-engineering in the human-only era can become positive-ROI once the modifier base shifts. This chapter recalibrates the criterion for \"worth designing for.\"",
				status: "published",
				href: "/research/cmp/practice/how-cheap-code-rewrites-design-bets/",
			},
			{
				num: 15,
				title: "Clean Architecture Revisited: From Overhead to Leverage",
				description:
					"Clean Architecture, Hexagonal, and Ports & Adapters were long dismissed as ceremony for most teams. In agentic engineering, their boundaries become high-leverage context routing: stable seams, explicit dependencies, and use-case isolation that make agents land changes in the right place. This chapter treats Clean Architecture as a concrete case study of agent-shifted ROI.",
				status: "planned",
			},
			{
				num: 16,
				title: "Post-Change Reflection: Closing the Loop One Modification at a Time",
				description:
					"The local-optimization trap, why both humans and agents need to reflect on context routing, and a post-change reflection skill that turns each modification into routing-repair feedback for locality and boundaries.",
				status: "planned",
			},
		],
	},
	{
		id: "agents",
		label: "Part V — Open Frontiers",
		chapters: [
			{
				num: 17,
				title: "Can Context Cost Be Measured?",
				description:
					"Context cost may not be directly measurable, but its traces can be observed: retrieved files, failed localization, missed edits, patch breadth, test failures, review corrections, and static structure. What would a credible, comparable metric look like?",
				status: "planned",
			},
			{
				num: 18,
				title: "What Does an Agent-Native Codebase Look Like?",
				description:
					"When the primary modifier of a codebase is no longer human, which design principles bend, break, or invert? This chapter opens the question of designing for non-human modifiers as a first-class audience.",
				status: "planned",
			},
			{
				num: 19,
				title: "How to Design a CMP-Native Coding Agent",
				description:
					"If CMP describes what makes a codebase modifiable, what does it imply for the agent doing the modifying? This chapter speculates on agent architecture: pre-modification context analysis, design-aware planning, post-change reflection loops, and the tooling surface an agent needs to act on context cost rather than just text.",
				status: "planned",
			},
		],
	},
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="cmp-page">
		<header>
			<h1>Context Minimization Principle</h1>
			<p class="lead">Software design is for modification.</p>
			<p class="lead">Correct modification requires sufficient context.</p>
			<p class="lead">Good design makes that context cheaper to acquire.</p>
			<blockquote class="intro">
				CMP is a framework for understanding software design as the discipline of reducing the cost of
				acquiring sufficient context for safe modification — for humans and AI agents alike.
			</blockquote>
		</header>

		<nav class="roadmap" aria-label="CMP book roadmap">
			<section class="roadmap-section">
				<h2>Start here</h2>
				<ol class="chapter-list" start={manifesto.num}>
					<li class="chapter">
						<div class="chapter-heading">
							{manifesto.status === "published" && manifesto.href ? (
								<a href={manifesto.href}>{manifesto.title}</a>
							) : (
								<span>{manifesto.title}</span>
							)}
							{manifesto.status === "planned" && <small class="status">Planned</small>}
						</div>
						<p>{manifesto.description}</p>
					</li>
				</ol>
			</section>

			{
				parts.map((part) => (
					<section class="roadmap-section">
						<h2>{part.label}</h2>
						<ol class="chapter-list" start={part.chapters[0]?.num}>
							{part.chapters.map((chapter) => (
								<li class="chapter">
									<div class="chapter-heading">
										{chapter.status === "published" && chapter.href ? (
											<a href={chapter.href}>{chapter.title}</a>
										) : (
											<span>{chapter.title}</span>
										)}
										{chapter.status === "planned" && <small class="status">Planned</small>}
									</div>
									<p>{chapter.description}</p>
								</li>
							))}
						</ol>
					</section>
				))
			}
		</nav>

		<section class="citation" aria-labelledby="citation-heading">
			<h2 id="citation-heading">Citation</h2>
			<p>If you reference this work in academic or technical writing, please cite:</p>
			<pre class="citation-bibtex" aria-label="BibTeX entry"><code>{`@online{zhang2026cmp,
  author  = {Zhang, Lianghui},
  title   = {Context Minimization Principle},
  year    = {2026},
  url     = {https://www.contextcost.dev/cmp/},
}`}</code></pre>
			<p class="citation-note">
				<a href={CMP_SOURCE_REPO} target="_blank" rel="noopener noreferrer">GitHub repository</a>
			</p>
		</section>
	</section>
</BaseLayout>

<style>
	.cmp-page {
		max-width: 860px;
		padding: 56px 0 8px;
	}

	.cmp-page header {
		padding-bottom: 18px;
		border-bottom: 1px solid var(--border);
	}

	.cmp-page h1 {
		margin-bottom: 16px;
	}

	.cmp-page .lead {
		font-size: 20px;
		line-height: 1.6;
		margin-bottom: 6px;
	}

	.intro {
		margin: 20px 0 0;
		padding: 0 0 0 1em;
		border-left: 3px solid var(--border);
		color: var(--secondary);
		font-size: 17px;
		line-height: 1.6;
	}

	.roadmap {
		padding-top: 28px;
	}

	.roadmap-section {
		margin-bottom: 36px;
	}

	.roadmap-section h2 {
		font-size: 20px;
		font-weight: 600;
		margin: 0 0 14px;
		color: var(--text);
		letter-spacing: -0.01em;
	}

	.chapter-list {
		margin: 0;
		padding-left: 28px;
		list-style: decimal;
	}

	.chapter {
		margin-bottom: 20px;
		padding-left: 4px;
	}

	.chapter-heading {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 8px 12px;
	}

	.chapter-heading a,
	.chapter-heading span {
		font-size: 17px;
		font-weight: 500;
		line-height: 1.35;
	}

	.chapter-heading span {
		color: var(--secondary);
	}

	.chapter p {
		margin: 6px 0 0;
		color: var(--secondary);
		font-size: 15px;
		line-height: 1.55;
	}

	.status {
		color: var(--text-muted);
		font-size: 11px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.citation {
		margin-top: 40px;
		padding-top: 28px;
		border-top: 1px solid var(--border);
	}

	.citation h2 {
		font-size: 18px;
		margin: 0 0 10px;
	}

	.citation > p {
		margin: 0 0 12px;
		color: var(--secondary);
		font-size: 15px;
		line-height: 1.55;
	}

	.citation-bibtex {
		margin: 0;
		padding: 14px 16px;
		border: 1px solid var(--border-light);
		border-radius: 8px;
		background: var(--bg-subtle, #f8f9fa);
		overflow-x: auto;
		font-size: 13px;
		line-height: 1.55;
	}

	.citation-bibtex code {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		color: var(--secondary);
		white-space: pre;
	}

	.citation-note {
		margin: 12px 0 0;
		font-size: 13px;
		color: var(--text-muted);
	}

	.citation-note a {
		color: var(--secondary);
	}

	@media (max-width: 700px) {
		.cmp-page {
			padding-top: 40px;
		}

		.cmp-page .lead {
			font-size: 18px;
		}

		.intro {
			font-size: 16px;
		}

		.chapter-heading a,
		.chapter-heading span {
			font-size: 16px;
		}
	}
</style>

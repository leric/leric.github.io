---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { publicProjects } from "../../data/projects";

const pageTitle = "Projects — Airic";
const pageDescription =
	"Open-source projects and research artifacts around context cost, modification workflows, AI agents, and architecture-aware software engineering.";

function projectUrl(project: (typeof publicProjects)[number]) {
	return project.primaryAction?.href || project.repo || "#";
}
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<section class="project-list" aria-label="Projects">
		{
			publicProjects.map((project) => (
				<article class="project-card">
					<div>
						<h2>
							<a href={projectUrl(project)} target="_blank" rel="noopener noreferrer">
								{project.name}
							</a>
						</h2>
						<p>{project.summary}</p>
						<div class="tag-row">
							{project.tags.slice(0, 5).map((tag) => (
								<span>{tag}</span>
							))}
						</div>
					</div>
					<a class="project-link" href={projectUrl(project)} target="_blank" rel="noopener noreferrer">
						GitHub ↗
					</a>
				</article>
			))
		}
	</section>
</BaseLayout>

<style>
	.project-list {
		padding: 32px 0 72px;
		display: grid;
		gap: 16px;
	}

	.project-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 24px;
		align-items: start;
		border: 1px solid var(--border);
		border-radius: var(--card-radius);
		background: white;
		padding: 24px;
		box-shadow: var(--shadow-sm);
	}

	.project-card h2 {
		font-size: 24px;
		margin: 0 0 10px;
	}

	.project-card h2 a {
		color: var(--primary);
		text-decoration: none;
	}

	.project-card h2 a:hover {
		color: var(--accent);
	}

	.project-card p {
		color: var(--secondary);
		font-size: 15px;
		line-height: 1.65;
		max-width: 720px;
		margin: 0 0 16px;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tag-row span {
		display: inline-flex;
		align-items: center;
		min-height: 26px;
		border: 1px solid var(--border-light);
		border-radius: 999px;
		background: var(--background-alt);
		color: var(--secondary);
		font-size: 11px;
		font-weight: 600;
		padding: 3px 9px;
	}

	.project-link {
		color: var(--accent);
		font-size: 14px;
		font-weight: 800;
		white-space: nowrap;
		text-decoration: none;
	}

	.project-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 760px) {
		.project-list {
			padding: 28px 0 48px;
		}

		.project-card {
			grid-template-columns: 1fr;
			gap: 16px;
			padding: 20px;
		}
	}
</style>

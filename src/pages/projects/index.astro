---
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = [
	{
		name: "Context Footprint",
		summary: "A prototype for estimating context acquisition cost in real codebases.",
		status: "experimental",
		linkLabel: "GitHub",
		linkHref: "https://github.com/airicdev/context-footprint",
	},
	{
		name: "Airic Agent",
		summary: "Agent workflow experiments for architecture-aware software modification.",
		status: "in progress",
		linkLabel: "GitHub",
		linkHref: "https://github.com/leric",
	},
	{
		name: "Other experiments",
		summary: "Small tools and notes that test parts of the CMP research agenda.",
		status: "planned",
	},
];
---

<BaseLayout title="Projects — Context Cost" description="Tools and prototypes related to CMP and context cost research.">
	<section class="projects">
		<header>
			<h1>Projects</h1>
			<p>Operational work around CMP. Secondary to the research writing, but built to test it in practice.</p>
		</header>

		<ul class="project-list">
			{projects.map((project) => (
				<li>
					<h2>{project.name}</h2>
					<p>{project.summary}</p>
					<div class="meta">
						<span class="status">{project.status}</span>
						{project.linkHref && project.linkLabel && (
							<>
								<span class="dot">·</span>
								<a href={project.linkHref} target="_blank" rel="noopener noreferrer">{project.linkLabel}</a>
							</>
						)}
					</div>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>

<style>
	.projects {
		max-width: 860px;
		padding: 52px 0 12px;
	}

	.projects header p {
		color: var(--secondary);
		max-width: 760px;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.project-list li {
		padding: 18px 0;
		border-top: 1px solid var(--border-light);
	}

	.project-list li:last-child {
		border-bottom: 1px solid var(--border-light);
	}

	.project-list h2 {
		font-size: 24px;
		margin: 0 0 8px;
	}

	.project-list p {
		margin: 0 0 6px;
		color: var(--secondary);
	}

	.meta {
		font-size: 13px;
		color: var(--text-muted);
	}

	.status {
		text-transform: lowercase;
	}

	.dot {
		margin: 0 6px;
	}

	@media (max-width: 700px) {
		.projects {
			padding-top: 40px;
		}

		.project-list h2 {
			font-size: 21px;
		}
	}
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = [
	{
		name: "CMP",
		summary: "Position paper proposing the Context Minimization Principle: a design is better when it reduces the context a developer or agent must load to answer an engineering query reliably.",
		status: "position paper",
		linkLabel: "GitHub",
		linkHref: "https://github.com/leric/cmp",
	},
	{
		name: "The Attention Cycle",
		summary: "Position paper on reducing supervision tax through executable documents—a loop where intent, execution, and verification stay in one evolving artifact.",
		status: "position paper",
		linkLabel: "GitHub",
		linkHref: "https://github.com/leric/attention-cycle",
	},
	{
		name: "Metadoc (Airic)",
		summary: "CLI prototype for a personal AI work partner built around Meta Documents and guided problem decomposition—treating agents, tasks, and workflows as structured Markdown.",
		status: "experimental",
		linkLabel: "GitHub",
		linkHref: "https://github.com/leric/metadoc",
	},
	{
		name: "HyperAPI",
		summary: "A performant API gateway in Rust with auth, load balancing, circuit breaking, rate limiting, and realtime config updates.",
		status: "maintained fork",
		linkLabel: "GitHub",
		linkHref: "https://github.com/leric/hyperapi",
	},
	{
		name: "Context Footprint",
		summary: "Research prototype that computes a Context Footprint metric—approximating how much code context must be traversed to analyze a symbol in a codebase.",
		status: "research preview",
		linkLabel: "GitHub",
		linkHref: "https://github.com/AiricDev/context-footprint",
	},
	{
		name: "AFII",
		summary: "Agent-Friendly Infrastructure Interface: a read-first operational CLI so agents can observe, diagnose, trigger repository-owned actions, and verify outcomes.",
		status: "in progress",
		linkLabel: "GitHub",
		linkHref: "https://github.com/AiricDev/AFII",
	},
];
---

<BaseLayout title="Projects — Context Cost" description="Tools and prototypes related to CMP and context cost research.">
	<section class="projects">
		<header>
			<h1>Projects</h1>
			<p>Operational work around CMP. Secondary to the research writing, but built to test it in practice.</p>
		</header>

		<ul class="project-list">
			{projects.map((project) => (
				<li>
					<h2>{project.name}</h2>
					<p>{project.summary}</p>
					<div class="meta">
						<span class="status">{project.status}</span>
						{project.linkHref && project.linkLabel && (
							<>
								<span class="dot">·</span>
								<a href={project.linkHref} target="_blank" rel="noopener noreferrer">{project.linkLabel}</a>
							</>
						)}
					</div>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>

<style>
	.projects {
		max-width: 860px;
		padding: 52px 0 12px;
	}

	.projects header p {
		color: var(--secondary);
		max-width: 760px;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.project-list li {
		padding: 18px 0;
		border-top: 1px solid var(--border-light);
	}

	.project-list li:last-child {
		border-bottom: 1px solid var(--border-light);
	}

	.project-list h2 {
		font-size: 24px;
		margin: 0 0 8px;
	}

	.project-list p {
		margin: 0 0 6px;
		color: var(--secondary);
	}

	.meta {
		font-size: 13px;
		color: var(--text-muted);
	}

	.status {
		text-transform: lowercase;
	}

	.dot {
		margin: 0 6px;
	}

	@media (max-width: 700px) {
		.projects {
			padding-top: 40px;
		}

		.project-list h2 {
			font-size: 21px;
		}
	}
</style>

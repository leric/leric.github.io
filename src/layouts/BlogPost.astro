---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogType="article">
	<article class="essay">
		<header class="essay-header">
			<h1>{title}</h1>
			<p class="essay-description">{description}</p>
			<p class="essay-meta">
				<FormattedDate date={pubDate} />
				{updatedDate && (
					<>
						<span class="dot">·</span>
						<span>Updated <FormattedDate date={updatedDate} /></span>
					</>
				)}
			</p>
		</header>

		{
			heroImage && (
				<figure class="essay-image">
					<img src={heroImage} alt={title} loading="eager" />
				</figure>
			)
		}

		<div class="essay-content">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.essay {
		max-width: var(--reading-width);
		padding: 52px 0 12px;
	}

	.essay-header {
		padding-bottom: 20px;
		border-bottom: 1px solid var(--border);
		margin-bottom: 26px;
	}

	.essay-description {
		font-size: 19px;
		line-height: 1.68;
		color: var(--secondary);
		margin: 0 0 10px;
	}

	.essay-meta {
		font-size: 13px;
		color: var(--text-muted);
		margin: 0;
	}

	.dot {
		padding: 0 6px;
	}

	.essay-image {
		margin: 0 0 32px;
	}

	.essay-image img {
		display: block;
		width: 100%;
		border-radius: 4px;
		margin: 0;
	}

	.essay-content {
		font-size: 18px;
		line-height: 1.75;
	}

	.essay-content :global(h2) {
		font-size: 29px;
		margin-top: 48px;
		margin-bottom: 14px;
	}

	.essay-content :global(h3) {
		font-size: 24px;
		margin-top: 34px;
		margin-bottom: 10px;
	}

	.essay-content :global(p),
	.essay-content :global(ul),
	.essay-content :global(ol),
	.essay-content :global(blockquote) {
		max-width: var(--reading-width);
	}

	@media (max-width: 768px) {
		.essay {
			padding-top: 40px;
		}

		.essay-description {
			font-size: 18px;
		}

		.essay-content {
			font-size: 17px;
		}
	}
</style>

---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostHog from '../components/posthog.astro';
import BookTocSidebar from '../components/research/BookTocSidebar.astro';
import ChapterOutline from '../components/research/ChapterOutline.astro';
import ChapterPager from '../components/research/ChapterPager.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { AUTHOR, cmpDiscussUrl } from '../consts';
import 'katex/dist/katex.min.css';

interface Props {
	entry: CollectionEntry<'research'>;
	title: string;
	description: string;
	canonicalUrl: string;
	image?: string;
	jsonLd: Record<string, unknown>;
	allChapters: CollectionEntry<'research'>[];
	prev?: CollectionEntry<'research'>;
	next?: CollectionEntry<'research'>;
}

const { entry, title, description, canonicalUrl, image, jsonLd, allChapters, prev, next } =
	Astro.props;

const ids = entry.id.match(/^cmp\/([^/]+)\/(.+)$/);
const part = ids?.[1] ?? entry.data.part;
const slug = ids?.[2] ?? '';

const wip = entry.data.status === 'wip';

const updated = entry.data.updatedDate ?? entry.data.pubDate;
---

<!doctype html>
<html lang={entry.data.lang ?? 'en'}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			canonicalHref={canonicalUrl}
			ogType="article"
			jsonLd={jsonLd}
		/>
		<PostHog />
	</head>
	<body class="research-book-body">
		<Header />
		<div class="research-shell">
			<div class="research-sidebar-left">
				<BookTocSidebar chapters={allChapters} currentPart={part} currentSlug={slug} />
			</div>
			<main class="research-main">
				<article class="research-chapter">
					<header class="research-chapter-header">
						{wip && <span class="wip-badge">Work in progress</span>}
						<h1 class="research-chapter-title">{entry.data.title}</h1>
						<p class="research-chapter-desc">{entry.data.description}</p>
						<div class="research-chapter-meta">
							<span>{AUTHOR.name}</span>
							<span>·</span>
							<span>v{entry.data.version}</span>
							<span>·</span>
							<span>Updated <FormattedDate date={updated} /></span>
						</div>
					</header>
					<div class="research-chapter-prose">
						<slot />
					</div>
					<ChapterPager prev={prev} next={next} />
					<footer class="research-chapter-footer">
						<div class="footer-row">
							<span class="footer-muted">Last updated</span>
							<FormattedDate date={updated} />
						</div>
						<p class="license-note">
							Unless otherwise noted, this CMP chapter is licensed under
							<a
								href="https://creativecommons.org/licenses/by/4.0/"
								target="_blank"
								rel="license noopener noreferrer">CC BY 4.0</a
							>.
						</p>
						<div class="footer-links">
							<a href={cmpDiscussUrl()} target="_blank" rel="noopener noreferrer"
								>Discuss this chapter</a
							>
						</div>
					</footer>
				</article>
			</main>
			<div class="research-sidebar-right">
				<ChapterOutline />
			</div>
		</div>
		<Footer />

		<style is:global>
			body.research-book-body {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			body.research-book-body main {
				max-width: none;
				padding: 0;
				flex: 1;
			}
		</style>
		<style>
			.research-shell {
				max-width: 1280px;
				margin: 0 auto;
				padding: 24px var(--content-padding) 64px;
				display: grid;
				grid-template-columns: minmax(200px, 240px) minmax(0, 1fr) minmax(200px, 230px);
				gap: 32px;
				align-items: stretch;
			}
			.research-main {
				min-width: 0;
			}
			.research-sidebar-left,
			.research-sidebar-right {
				min-width: 0;
			}
			.research-chapter-header {
				margin-bottom: 28px;
				padding-bottom: 24px;
				border-bottom: 1px solid var(--border);
			}
			.wip-badge {
				display: inline-block;
				font-size: 11px;
				font-weight: 800;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				background: var(--warning);
				color: #1a1a1a;
				padding: 4px 10px;
				border-radius: 999px;
				margin-bottom: 12px;
			}
			.research-chapter-title {
				font-size: clamp(26px, 4vw, 36px);
				font-weight: 800;
				letter-spacing: -0.03em;
				margin: 0 0 12px;
			}
			.research-chapter-desc {
				font-size: 17px;
				color: var(--secondary);
				line-height: 1.55;
				margin: 0 0 16px;
			}
			.research-chapter-meta {
				font-size: 14px;
				color: var(--text-muted);
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
			}
			.research-chapter-prose {
				font-size: 17px;
				line-height: 1.75;
				color: var(--primary);
				font-family:
					var(--font-primary),
					'PingFang SC',
					'Microsoft YaHei',
					'Noto Sans SC',
					sans-serif;
			}
			.research-chapter-prose :global(h2) {
				font-size: 22px;
				margin-top: 64px;
				margin-bottom: 10px;
			}
			.research-chapter-prose :global(h3) {
				font-size: 18px;
				margin-top: 40px;
				margin-bottom: 8px;
			}
			.research-chapter-prose :global(p) {
				margin-bottom: 18px;
			}
			.research-chapter-prose :global(.cmp-tldr) {
				margin: 0 0 40px;
				padding: 20px 22px 18px;
				border: 1px solid var(--border-light);
				border-left: 4px solid var(--accent);
				border-radius: 8px;
				background: var(--bg-subtle, #f8f9fa);
			}
			.research-chapter-prose :global(.cmp-tldr h2) {
				margin-top: 0;
				margin-bottom: 14px;
				font-size: 12px;
				font-weight: 800;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent);
			}
			.research-chapter-prose :global(.cmp-tldr p) {
				margin-bottom: 14px;
				font-size: 16px;
				line-height: 1.65;
				color: var(--secondary);
			}
			.research-chapter-prose :global(.cmp-tldr p:last-child) {
				margin-bottom: 0;
			}
			.research-chapter-prose :global(.footnotes) {
				margin-top: 40px;
				padding-top: 20px;
				border-top: 1px solid var(--border-light);
				font-size: 15px;
			}
			.research-chapter-prose :global(figure) {
				margin: 28px 0;
			}
			.research-chapter-prose :global(figcaption) {
				font-size: 14px;
				color: var(--secondary);
				margin-top: 10px;
				line-height: 1.5;
			}
			.research-chapter-prose :global(table) {
				width: 100%;
				margin: 28px 0;
				border-collapse: collapse;
				border: 1px solid var(--border);
				font-size: 15px;
				line-height: 1.55;
			}
			.research-chapter-prose :global(thead) {
				background: var(--bg-subtle, #f8f9fa);
			}
			.research-chapter-prose :global(th),
			.research-chapter-prose :global(td) {
				border: 1px solid var(--border);
				padding: 10px 14px;
				text-align: left;
				vertical-align: top;
			}
			.research-chapter-prose :global(th) {
				font-weight: 600;
				color: var(--primary);
			}
			.research-chapter-prose :global(td) {
				color: var(--primary);
			}
			.research-chapter-prose :global(tbody tr:nth-child(even)) {
				background: color-mix(in srgb, var(--bg-subtle, #f8f9fa) 55%, transparent);
			}
			@media (max-width: 640px) {
				.research-chapter-prose :global(table) {
					display: block;
					overflow-x: auto;
					-webkit-overflow-scrolling: touch;
				}
			}
			.research-chapter-prose :global(.katex-display) {
				overflow-x: auto;
				padding: 8px 0;
			}
			.research-chapter-prose :global(.cmp-code-details) {
				margin: 20px 0;
				border: 1px solid var(--border-light);
				border-radius: 8px;
				background: var(--bg-subtle, #f8f9fa);
			}
			.research-chapter-prose :global(.cmp-code-details summary) {
				cursor: pointer;
				font-weight: 600;
				font-size: 15px;
				color: var(--primary);
				padding: 12px 14px;
				list-style: none;
			}
			.research-chapter-prose :global(.cmp-code-details summary::-webkit-details-marker) {
				display: none;
			}
			.research-chapter-prose :global(.cmp-code-details summary::before) {
				content: '▸ ';
				display: inline-block;
				margin-right: 4px;
				color: var(--accent);
				transition: transform 0.15s ease;
			}
			.research-chapter-prose :global(.cmp-code-details[open] summary::before) {
				transform: rotate(90deg);
			}
			.research-chapter-prose :global(.cmp-code-details pre) {
				margin: 0;
				border-radius: 0 0 8px 8px;
				border-top: 1px solid var(--border-light);
			}
			.research-chapter-footer {
				margin-top: 32px;
				padding-top: 20px;
				border-top: 1px solid var(--border-light);
				font-size: 14px;
			}
			.footer-row {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-bottom: 10px;
			}
			.license-note {
				color: var(--secondary);
				line-height: 1.5;
				margin: 0 0 10px;
			}
			.footer-muted {
				color: var(--text-muted);
			}
			.footer-links {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 4px;
			}
			@media (max-width: 1080px) {
				.research-shell {
					grid-template-columns: 1fr;
				}
				.research-sidebar-right {
					order: 3;
				}
			}
		</style>
	</body>
</html>

---
---

<aside class="chapter-outline" aria-label="On this page">
	<p class="outline-heading">On this page</p>
	<nav id="chapter-outline-nav" class="outline-nav"></nav>
</aside>

<script>
	// Track teardown for the previously-built outline so SPA page transitions
	// (astro:page-load) don't stack scroll listeners.
	let outlineCleanup: (() => void) | null = null;

	function buildOutline() {
		outlineCleanup?.();
		outlineCleanup = null;

		const root = document.querySelector('.research-chapter-prose');
		const nav = document.getElementById('chapter-outline-nav');
		if (!root || !nav) return;

		const headings = Array.from(root.querySelectorAll('h2, h3')) as HTMLElement[];
		nav.innerHTML = '';
		const frag = document.createDocumentFragment();
		const linkByHeading = new Map<HTMLElement, HTMLAnchorElement>();

		headings.forEach((el) => {
			if (!(el instanceof HTMLElement)) return;
			let id = el.id;
			if (!id) {
				id = el.textContent?.trim().toLowerCase().replace(/\s+/g, '-').slice(0, 64) ?? 'section';
				el.id = id;
			}
			const fullText = el.textContent ?? '';
			// For h2, strip subtitle after ': ' or ' — ' to keep labels compact
			let displayText = fullText;
			if (el.tagName === 'H2') {
				const colon = fullText.indexOf(': ');
				const dash = fullText.indexOf(' — ');
				const cut = [colon, dash].filter((i) => i > 0).sort((a, b) => a - b)[0];
				if (cut !== undefined) displayText = fullText.slice(0, cut);
			}
			const a = document.createElement('a');
			a.href = `#${id}`;
			a.textContent = displayText;
			if (displayText !== fullText) a.title = fullText;
			a.className = el.tagName === 'H3' ? 'outline-link depth-3' : 'outline-link';
			linkByHeading.set(el, a);
			frag.appendChild(a);
		});
		nav.appendChild(frag);

		if (headings.length === 0) return;

		const sidebar = document.querySelector('.chapter-outline') as HTMLElement | null;
		let currentActive: HTMLAnchorElement | null = null;

		function setActive(link: HTMLAnchorElement | null) {
			if (link === currentActive) return;
			currentActive?.classList.remove('active');
			link?.classList.add('active');
			currentActive = link;
			if (link && sidebar) {
				const linkRect = link.getBoundingClientRect();
				const sidebarRect = sidebar.getBoundingClientRect();
				const relTop = linkRect.top - sidebarRect.top;
				const relBottom = relTop + linkRect.height;
				if (relTop < 24) {
					sidebar.scrollBy({ top: relTop - 24, behavior: 'smooth' });
				} else if (relBottom > sidebar.clientHeight - 24) {
					sidebar.scrollBy({
						top: relBottom - sidebar.clientHeight + 24,
						behavior: 'smooth',
					});
				}
			}
		}

		// Pick the last heading whose top has crossed an "active line" near the top
		// of the viewport (just below the sticky sidebar's top offset).
		function pickActive() {
			const activeLine = 96;
			let active: HTMLElement = headings[0];
			for (const h of headings) {
				if (h.getBoundingClientRect().top - activeLine <= 0) {
					active = h;
				} else {
					break;
				}
			}
			// If we've scrolled to the very bottom of the document, force-select the
			// last heading so the tail of the article still highlights correctly.
			const nearBottom =
				window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
			if (nearBottom) active = headings[headings.length - 1];
			setActive(linkByHeading.get(active) ?? null);
		}

		let rafId = 0;
		function schedule() {
			if (rafId) return;
			rafId = requestAnimationFrame(() => {
				rafId = 0;
				pickActive();
			});
		}

		window.addEventListener('scroll', schedule, { passive: true });
		window.addEventListener('resize', schedule, { passive: true });

		// Initial pick (and one more after layout settles, since fonts/MDX content
		// can shift heading positions slightly after the first frame).
		pickActive();
		const settleTimer = window.setTimeout(pickActive, 120);

		outlineCleanup = () => {
			window.removeEventListener('scroll', schedule);
			window.removeEventListener('resize', schedule);
			window.clearTimeout(settleTimer);
			if (rafId) cancelAnimationFrame(rafId);
		};
	}

	buildOutline();
	document.addEventListener('astro:page-load', buildOutline);
</script>

<style>
	.chapter-outline {
		position: sticky;
		top: 24px;
		font-size: 13px;
		max-height: calc(100vh - 48px);
		overflow-y: auto;
		scrollbar-width: thin;
	}

	.outline-heading {
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 10px;
	}

	.outline-nav {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	/*
	 * Outline links are created at runtime by the buildOutline() script below.
	 * Dynamically created nodes do not receive Astro's scoped-styles data attribute,
	 * so we use :global() (constrained to .outline-nav descendants) to make sure
	 * the layout and .active highlight rules actually apply to them.
	 */
	.outline-nav :global(.outline-link) {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		overflow: hidden;
		overflow-wrap: anywhere;
		color: var(--secondary);
		text-decoration: none;
		line-height: 1.4;
		padding: 5px 8px 5px 12px;
		border-left: 2px solid transparent;
		margin-left: -2px;
		border-radius: 0 4px 4px 0;
		transition: color 0.12s, border-color 0.12s, background 0.12s;
	}

	.outline-nav :global(.outline-link:hover) {
		color: var(--primary);
		border-left-color: var(--border-light);
	}

	.outline-nav :global(.outline-link.active) {
		color: var(--accent);
		border-left-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 6%, transparent);
	}

	.outline-nav :global(.outline-link.depth-3) {
		padding-left: 22px;
		font-size: 11.5px;
		color: var(--text-muted);
		-webkit-line-clamp: 2;
		line-clamp: 2;
	}

	.outline-nav :global(.outline-link.depth-3:hover) {
		color: var(--secondary);
	}

	.outline-nav :global(.outline-link.depth-3.active) {
		color: var(--accent);
	}

	@media (max-width: 1080px) {
		.chapter-outline {
			display: none;
		}
	}
</style>

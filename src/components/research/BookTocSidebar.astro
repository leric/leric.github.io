---
import type { CollectionEntry } from 'astro:content';
import {
	CMP_PART_LABELS,
	CMP_PART_ORDER,
	CMP_START_PART,
	cmpChapterPath,
	isCmpChapterPublished,
	parseCmpEntryId,
} from '../../lib/research-cmp';

interface Props {
	chapters: CollectionEntry<'research'>[];
	currentPart: string;
	currentSlug: string;
}

const { chapters, currentPart, currentSlug } = Astro.props;

const byPart = new Map<string, CollectionEntry<'research'>[]>();
for (const p of CMP_PART_ORDER) {
	byPart.set(p, []);
}
for (const ch of chapters) {
	if (!isCmpChapterPublished(ch.data.status)) continue;
	const list = byPart.get(ch.data.part) ?? [];
	list.push(ch);
	byPart.set(ch.data.part, list);
}
for (const [, list] of byPart) {
	list.sort((a, b) => a.data.order - b.data.order);
}

const partsWithChapters = CMP_PART_ORDER.filter((partId) => (byPart.get(partId)?.length ?? 0) > 0);
---

<nav class="book-toc" aria-label="Book table of contents">
	<p class="book-toc-heading">CMP</p>
	{
		partsWithChapters.map((partId, index) => {
			const items = byPart.get(partId) ?? [];
			const showDivider = index > 0;
			const showPartLabel = partId !== CMP_START_PART;

			return (
				<div class="book-toc-group">
					{showDivider && <hr class="book-toc-divider" />}
					{showPartLabel && <p class="book-toc-part-label">{CMP_PART_LABELS[partId]}</p>}
					<ul class="book-toc-chapters">
						{items.map((ch) => {
							const ids = parseCmpEntryId(ch.id);
							const slug = ids?.slug ?? '';
							const href = ids ? cmpChapterPath(ids.part, ids.slug) : '#';
							const active = ch.data.part === currentPart && slug === currentSlug;
							return (
								<li>
									<a href={href} class:list={['toc-link', { active }]}>
										{ch.data.title}
									</a>
								</li>
							);
						})}
					</ul>
				</div>
			);
		})
	}
</nav>

<style>
	.book-toc {
		font-size: 13px;
		line-height: 1.45;
	}

	.book-toc-heading {
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 12px;
	}

	.book-toc-group {
		margin: 0;
	}

	.book-toc-divider {
		margin: 14px 0;
		border: none;
		border-top: 1px solid var(--border-light);
	}

	.book-toc-part-label {
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 8px;
	}

	.book-toc-chapters {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.book-toc-chapters li {
		margin-bottom: 6px;
	}

	.toc-link {
		display: block;
		color: var(--secondary);
		text-decoration: none;
		font-weight: 500;
		padding: 4px 0;
		border-radius: 4px;
	}

	.toc-link:hover {
		color: var(--accent);
	}

	.toc-link.active {
		color: var(--accent);
		font-weight: 700;
	}
</style>

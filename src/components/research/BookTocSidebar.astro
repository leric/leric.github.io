---
import type { CollectionEntry } from 'astro:content';
import {
	CMP_PART_LABELS,
	CMP_PART_ORDER,
	cmpChapterPath,
	isCmpChapterPublished,
	parseCmpEntryId,
} from '../../lib/research-cmp';

interface Props {
	chapters: CollectionEntry<'research'>[];
	currentPart: string;
	currentSlug: string;
}

const { chapters, currentPart, currentSlug } = Astro.props;

const byPart = new Map<string, CollectionEntry<'research'>[]>();
for (const p of CMP_PART_ORDER) {
	byPart.set(p, []);
}
for (const ch of chapters) {
	if (!isCmpChapterPublished(ch.data.status)) continue;
	const list = byPart.get(ch.data.part) ?? [];
	list.push(ch);
	byPart.set(ch.data.part, list);
}
for (const [, list] of byPart) {
	list.sort((a, b) => a.data.order - b.data.order);
}
---

<nav class="book-toc" aria-label="Book table of contents">
	<p class="book-toc-heading">CMP</p>
	{
		CMP_PART_ORDER.map((partId) => {
			const items = byPart.get(partId) ?? [];
			if (items.length === 0) return null;
			const open = partId === currentPart;
			return (
				<details class="book-toc-part" open={open}>
					<summary>{CMP_PART_LABELS[partId]}</summary>
					<ul>
						{items.map((ch) => {
							const ids = parseCmpEntryId(ch.id);
							const slug = ids?.slug ?? '';
							const href = ids ? cmpChapterPath(ids.part, ids.slug) : '#';
							const active = ch.data.part === currentPart && slug === currentSlug;
							return (
								<li>
									<a href={href} class:list={['toc-link', { active }]}>
										{ch.data.title}
									</a>
								</li>
							);
						})}
					</ul>
				</details>
			);
		})
	}
</nav>

<style>
	.book-toc {
		font-size: 13px;
		line-height: 1.45;
	}
	.book-toc-heading {
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 12px;
	}
	.book-toc-part {
		border: 1px solid var(--border-light);
		border-radius: 8px;
		margin-bottom: 8px;
		background: white;
	}
	.book-toc-part summary {
		cursor: pointer;
		font-weight: 700;
		color: var(--primary);
		padding: 10px 12px;
		list-style: none;
	}
	.book-toc-part summary::-webkit-details-marker {
		display: none;
	}
	.book-toc-part ul {
		margin: 0;
		padding: 0 8px 10px 12px;
		list-style: none;
	}
	.book-toc-part li {
		margin-bottom: 6px;
	}
	.toc-link {
		display: block;
		color: var(--secondary);
		text-decoration: none;
		font-weight: 500;
		padding: 4px 0;
		border-radius: 4px;
	}
	.toc-link:hover {
		color: var(--accent);
	}
	.toc-link.active {
		color: var(--accent);
		font-weight: 700;
	}
	.toc-soon {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
		color: var(--text-muted);
		padding: 4px 0;
	}
	.soon-pill {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 1px 6px;
		flex-shrink: 0;
	}
</style>

---
import type { CollectionEntry } from 'astro:content';
import {
	CMP_PART_LABELS,
	CMP_PART_ORDER,
	CMP_START_PART,
	cmpChapterPath,
	isCmpChapterPublished,
	parseCmpEntryId,
} from '../../lib/research-cmp';

interface Props {
	chapters: CollectionEntry<'research'>[];
	currentPart: string;
	currentSlug: string;
}

const { chapters, currentPart, currentSlug } = Astro.props;

const byPart = new Map<string, CollectionEntry<'research'>[]>();
for (const p of CMP_PART_ORDER) {
	byPart.set(p, []);
}
for (const ch of chapters) {
	if (!isCmpChapterPublished(ch.data.status)) continue;
	const list = byPart.get(ch.data.part) ?? [];
	list.push(ch);
	byPart.set(ch.data.part, list);
}
for (const [, list] of byPart) {
	list.sort((a, b) => a.data.order - b.data.order);
}

const partsWithChapters = CMP_PART_ORDER.filter((partId) => (byPart.get(partId)?.length ?? 0) > 0);

// Compute absolute chapter numbers across all parts in order
let chapterCounter = 0;
const chapterNum = new Map<string, number>();
for (const partId of CMP_PART_ORDER) {
	for (const ch of byPart.get(partId) ?? []) {
		chapterCounter++;
		chapterNum.set(ch.id, chapterCounter);
	}
}

// Short title: strip subtitle after " — " or ": " for the left sidebar
function shortTitle(title: string): string {
	const colonIdx = title.indexOf(': ');
	const dashIdx = title.indexOf(' — ');
	const cut = [colonIdx, dashIdx].filter((i) => i > 0).sort((a, b) => a - b)[0];
	return cut !== undefined ? title.slice(0, cut) : title;
}
---

<nav class="book-toc" aria-label="Book table of contents">
	<p class="book-toc-heading">CMP</p>
	{
		partsWithChapters.map((partId, index) => {
			const items = byPart.get(partId) ?? [];
			const showDivider = index > 0;
			const showPartLabel = partId !== CMP_START_PART;

			return (
				<div class="book-toc-group">
					{showDivider && <hr class="book-toc-divider" />}
					{showPartLabel && <p class="book-toc-part-label">{CMP_PART_LABELS[partId]}</p>}
					<ul class="book-toc-chapters">
						{items.map((ch) => {
							const ids = parseCmpEntryId(ch.id);
							const slug = ids?.slug ?? '';
							const href = ids ? cmpChapterPath(ids.part, ids.slug) : '#';
							const active = ch.data.part === currentPart && slug === currentSlug;
							const num = chapterNum.get(ch.id);
							const title = shortTitle(ch.data.title);
							return (
								<li>
									<a href={href} class:list={['toc-link', { active }]} title={ch.data.title}>
										{num && <span class="toc-num">{num}</span>}
										<span class="toc-title">{title}</span>
									</a>
								</li>
							);
						})}
					</ul>
				</div>
			);
		})
	}
</nav>

<style>
	.book-toc {
		font-size: 13px;
		line-height: 1.45;
		position: sticky;
		top: 88px;
		max-height: calc(100vh - 120px);
		overflow-y: auto;
		scrollbar-width: thin;
	}

	.book-toc-heading {
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 12px;
	}

	.book-toc-group {
		margin: 0;
	}

	.book-toc-divider {
		margin: 14px 0;
		border: none;
		border-top: 1px solid var(--border-light);
	}

	.book-toc-part-label {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 6px;
	}

	.book-toc-chapters {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.book-toc-chapters li {
		margin-bottom: 2px;
	}

	.toc-link {
		display: flex;
		align-items: baseline;
		gap: 7px;
		color: var(--secondary);
		text-decoration: none;
		font-weight: 400;
		padding: 4px 8px 4px 10px;
		border-radius: 4px;
		border-left: 2px solid transparent;
		margin-left: -2px;
		transition: color 0.12s, border-color 0.12s;
	}

	.toc-link:hover {
		color: var(--primary);
		border-left-color: var(--border-light);
	}

	.toc-link.active {
		color: var(--accent);
		font-weight: 600;
		border-left-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 6%, transparent);
	}

	.toc-num {
		flex: 0 0 auto;
		font-size: 11px;
		font-variant-numeric: tabular-nums;
		color: var(--text-muted);
		min-width: 14px;
		line-height: 1;
		padding-top: 1px;
	}

	.toc-link.active .toc-num {
		color: var(--accent);
	}

	.toc-title {
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		line-clamp: 2;
	}
</style>

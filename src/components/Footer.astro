---
import { AUTHOR, SITE_TITLE } from "../consts";
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-container">
		<div class="footer-main">
			<p class="footer-name">{SITE_TITLE}</p>
			<p class="footer-bio">{AUTHOR.bio}</p>
			<nav class="footer-links" aria-label="Footer links">
				{AUTHOR.social.github && <a href={AUTHOR.social.github} target="_blank" rel="noopener">GitHub</a>}
				{AUTHOR.social.medium && <a href={AUTHOR.social.medium} target="_blank" rel="noopener">Medium</a>}
				<a href="/rss.xml">RSS</a>
				{AUTHOR.social.email && <a href={AUTHOR.social.email}>Email</a>}
			</nav>
		</div>
		<p class="footer-bottom">&copy; {today.getFullYear()} {SITE_TITLE}</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--border);
		margin-top: 72px;
	}

	.footer-container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 28px var(--content-padding);
	}

	.footer-main {
		display: grid;
		gap: 10px;
	}

	.footer-name {
		font-size: 14px;
		font-weight: 600;
		margin: 0;
	}

	.footer-bio {
		color: var(--text-muted);
		font-size: 14px;
		line-height: 1.6;
		margin: 0;
		max-width: 720px;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		font-size: 14px;
	}

	.footer-bottom {
		margin: 0;
		padding-top: 18px;
		color: var(--text-muted);
		font-size: 12px;
	}

	@media (max-width: 768px) {
		.footer-container {
			padding: 24px var(--content-padding);
		}
	}
</style>

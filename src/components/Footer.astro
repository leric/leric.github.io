---
import { AUTHOR } from "../consts";
---

<footer class="site-footer">
	<div class="footer-container">
		<nav class="footer-links" aria-label="Footer links">
			<a href="/about">About</a>
			{AUTHOR.social.github && <a href={AUTHOR.social.github} target="_blank" rel="noopener">GitHub</a>}
			<a href="/rss.xml">RSS</a>
			{AUTHOR.social.email && <a href={AUTHOR.social.email}>Email</a>}
		</nav>
		<p class="footer-bottom">&copy; {AUTHOR.citationName} · contextcost.dev</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--border);
		margin-top: 72px;
	}

	.footer-container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 28px var(--content-padding);
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		font-size: 14px;
	}

	.footer-bottom {
		margin: 0;
		padding-top: 18px;
		color: var(--text-muted);
		font-size: 12px;
	}

	@media (max-width: 768px) {
		.footer-container {
			padding: 24px var(--content-padding);
		}
	}
</style>

---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR } from '../consts';
---

<header class="site-header">
	<div class="header-container">
		<div class="header-brand">
			<a href="/" class="brand-link">
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-tagline">{SITE_DESCRIPTION}</span>
			</a>
		</div>
		<nav class="header-nav" aria-label="Primary">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/cmp">CMP</HeaderLink>
			<HeaderLink href="/blog">Essays</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</nav>
		<div class="header-actions">
			{
				AUTHOR.social.github && (
					<a
						class="icon-link"
						href={AUTHOR.social.github}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub profile"
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							></path>
						</svg>
					</a>
				)
			}
		</div>
	</div>
</header>

<style>
	.site-header {
		background: var(--background);
		border-bottom: 1px solid var(--border);
	}

	.header-container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--content-padding);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		min-height: 68px;
	}

	.header-brand {
		flex-shrink: 0;
	}

	.brand-link {
		text-decoration: none;
		color: var(--primary);
		display: block;
	}

	.brand-title {
		font-family: var(--font-primary);
		font-size: 18px;
		font-weight: 600;
		letter-spacing: -0.01em;
		display: block;
		line-height: 1.2;
	}

	.brand-tagline {
		font-size: 11px;
		color: var(--text-muted);
		font-weight: 400;
		margin-top: 2px;
		display: block;
		letter-spacing: 0;
	}

	.header-nav {
		display: flex;
		align-items: center;
		gap: 20px;
		flex: 1;
		justify-content: center;
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-shrink: 0;
	}

	.icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--secondary);
		text-decoration: none;
		font-size: 12px;
		font-weight: 500;
		padding: 4px 6px;
		transition:
			color 0.15s ease;
	}

	.icon-link:hover {
		color: var(--accent);
	}

	.rss-link {
		min-width: 36px;
	}

	@media (max-width: 768px) {
		.header-container {
			min-height: 62px;
			flex-wrap: wrap;
		}

		.header-nav {
			order: 3;
			width: 100%;
			justify-content: flex-start;
			gap: 16px;
			padding-bottom: 8px;
		}

		.brand-title {
			font-size: 17px;
		}

		.brand-tagline {
			font-size: 11px;
		}
	}

	@media (max-width: 640px) {
		.header-nav {
			gap: 12px;
		}
	}
</style>

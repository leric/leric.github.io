# Auto detect text files and normalize to LF in the repo
* text=auto

# Source code — text, LF in repo, OS-native on checkout
*.astro text
*.css   text
*.html  text
*.js    text
*.json  text
*.mjs   text
*.md    text
*.mdx   text
*.ts    text
*.xml   text
*.yaml  text
*.yml   text
*.toml  text
*.cff   text
*.txt   text

# Shell scripts — force LF (must stay LF even on Windows)
*.sh  text eol=lf

# Binaries — never touch
*.ico    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.woff   binary
*.woff2  binary
*.pdf    binary
*.zip    binary
